# GEMINI_MODEL=gemini-3.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_repo_name
